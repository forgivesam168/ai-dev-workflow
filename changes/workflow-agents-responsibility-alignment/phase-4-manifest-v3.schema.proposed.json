{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-dev-workflow/phase-4-manifest-v3.schema.proposed.json",
  "title": "AI Workflow Install Manifest v3 Candidate",
  "description": "PROPOSED — NOT APPROVED — NOT IMPLEMENTED. This schema is design evidence only and must not be imported by production readers, writers, tests, or gates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_status",
    "schema_version",
    "written_at",
    "source_release",
    "last_transaction",
    "components"
  ],
  "properties": {
    "proposal_status": {
      "const": "PROPOSED — NOT APPROVED — NOT IMPLEMENTED"
    },
    "schema_version": {
      "const": 3
    },
    "written_at": {
      "$ref": "#/$defs/timestamp"
    },
    "source_release": {
      "$ref": "#/$defs/sourceRelease"
    },
    "last_transaction": {
      "$ref": "#/$defs/transaction"
    },
    "components": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/component"
      },
      "$comment": "Writers sort components by identity.id. Readers reject duplicate identity.id and duplicate active identity.path_key values. One tombstoned record and one active record may share a path key only when the active record explicitly reintroduces that tombstoned ID and the tombstoned target is absent; JSON Schema cannot express those cross-record rules."
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
    },
    "hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "componentId": {
      "type": "string",
      "minLength": 7,
      "maxLength": 132,
      "pattern": "^cmp:[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)[A-Za-z0-9@+_.-]+(?:/[A-Za-z0-9@+_.-]+)*$",
      "$comment": "Forward-slash repository-relative logical path only. Absolute paths, backslashes, empty segments, dot segments, and parent traversal are invalid. Runtime validation also rejects Windows reserved names, trailing dot/space aliases, root escapes after link resolution, and case collisions."
    },
    "pathKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[a-z0-9@+_.-]+(?:/[a-z0-9@+_.-]+)*$",
      "$comment": "ASCII lowercase of the normalized relative path. Readers verify equality with lower(identity.path) and reject duplicate active keys on every platform. A tombstone/active same-key exception requires the explicit reintroduction relationship and semantic validation."
    },
    "sourceRelease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_id",
        "source_ref",
        "version",
        "component_catalog"
      ],
      "properties": {
        "release_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "source_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "component_catalog": {
          "$ref": "#/$defs/componentCatalogBinding"
        }
      }
    },
    "componentCatalogBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "schema_version",
        "sha256"
      ],
      "properties": {
        "path": {
          "const": "manifest/component-catalog.json"
        },
        "schema_version": {
          "const": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "$comment": "This binding identifies the version-controlled canonical component catalog for the source release. Semantic validation requires the digest to match exact catalog bytes and every manifest identity/provenance relationship to match that catalog."
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "mode",
        "writer",
        "started_at",
        "completed_at",
        "result"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 7,
          "maxLength": 132,
          "pattern": "^txn:[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "mode": {
          "enum": [
            "install",
            "update",
            "migration"
          ]
        },
        "writer": {
          "enum": [
            "python",
            "powershell"
          ]
        },
        "started_at": {
          "$ref": "#/$defs/timestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/timestamp"
        },
        "result": {
          "const": "committed"
        }
      },
      "$comment": "A v3 manifest is published only after a recoverable transaction commits. Dry-run, parse failure, and interrupted transaction outcomes are diagnostics or journal state, never fabricated manifest state."
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "path_key",
        "kind",
        "role",
        "link"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/componentId"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "path_key": {
          "$ref": "#/$defs/pathKey"
        },
        "kind": {
          "enum": [
            "file",
            "directory",
            "mount",
            "link"
          ]
        },
        "role": {
          "enum": [
            "canonical",
            "generated",
            "project-owned",
            "compatibility"
          ]
        },
        "link": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/link"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "mount",
                  "link"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "link": {
                "$ref": "#/$defs/link"
              }
            }
          },
          "else": {
            "properties": {
              "link": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "link"
              }
            }
          },
          "then": {
            "properties": {
              "link": {
                "properties": {
                  "mode": {
                    "const": "symlink"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_path",
        "target_path_key",
        "mode"
      ],
      "properties": {
        "target_path": {
          "$ref": "#/$defs/relativePath"
        },
        "target_path_key": {
          "$ref": "#/$defs/pathKey"
        },
        "mode": {
          "enum": [
            "symlink",
            "junction",
            "copy-fallback"
          ]
        }
      },
      "$comment": "Targets are repository-root-relative logical paths, not raw filesystem link text. Runtime inspection resolves them without following an escape outside the adopter root."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "locator",
        "release"
      ],
      "properties": {
        "kind": {
          "enum": [
            "template",
            "project",
            "generated",
            "legacy",
            "unknown"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 3,
          "maxLength": 512,
          "pattern": "^(?:template|project|generated|legacy|unknown):[A-Za-z0-9@+_.:/#-]+$"
        },
        "release": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 128
        }
      },
      "$comment": "The semantic validator rejects locator traversal, absolute filesystem paths, and a prefix that disagrees with kind."
    },
    "fork": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "basis",
        "decision",
        "classified_at"
      ],
      "properties": {
        "status": {
          "enum": [
            "untouched",
            "customized",
            "project-owned",
            "legacy",
            "unknown",
            "derived-customized",
            "conflicted",
            "not-applicable"
          ]
        },
        "basis": {
          "enum": [
            "verified-managed-equality",
            "hash-divergence",
            "explicit-project-ownership",
            "legacy-import",
            "missing-lineage",
            "derived-hash-divergence",
            "conflicting-evidence",
            "hash-not-applicable"
          ]
        },
        "decision": {
          "enum": [
            "manage",
            "preserve",
            "report-only",
            "block"
          ]
        },
        "classified_at": {
          "$ref": "#/$defs/timestamp"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "untouched"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "verified-managed-equality"
              },
              "decision": {
                "const": "manage"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "customized"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "hash-divergence"
              },
              "decision": {
                "const": "preserve"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "project-owned"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "explicit-project-ownership"
              },
              "decision": {
                "const": "preserve"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unknown"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "missing-lineage"
              },
              "decision": {
                "const": "report-only"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "legacy"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "legacy-import"
              },
              "decision": {
                "const": "report-only"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "derived-customized"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "derived-hash-divergence"
              },
              "decision": {
                "const": "preserve"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "conflicted"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "conflicting-evidence"
              },
              "decision": {
                "const": "block"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "not-applicable"
              }
            }
          },
          "then": {
            "properties": {
              "basis": {
                "const": "hash-not-applicable"
              },
              "decision": {
                "const": "report-only"
              }
            }
          }
        }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownership",
        "source",
        "generated_from",
        "fork"
      ],
      "properties": {
        "ownership": {
          "enum": [
            "template-managed",
            "project-owned",
            "derived-runtime",
            "legacy-compat",
            "unknown"
          ]
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "generated_from": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/componentId"
          }
        },
        "fork": {
          "$ref": "#/$defs/fork"
        }
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "content_basis",
        "baseline",
        "observed_before",
        "proposed_source",
        "result_after"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "content_basis": {
          "const": "exact-bytes"
        },
        "baseline": {
          "$ref": "#/$defs/hash"
        },
        "observed_before": {
          "$ref": "#/$defs/hash"
        },
        "proposed_source": {
          "$ref": "#/$defs/hash"
        },
        "result_after": {
          "$ref": "#/$defs/hash"
        }
      }
    },
    "retirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "detected_at",
        "source_evidence",
        "successor_component_id",
        "pruned_at"
      ],
      "properties": {
        "reason": {
          "enum": [
            "renamed",
            "deleted",
            "source-retired",
            "superseded"
          ]
        },
        "detected_at": {
          "$ref": "#/$defs/timestamp"
        },
        "source_evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "locator"
          ],
          "properties": {
            "type": {
              "enum": [
                "rename-map",
                "component-absent-in-source",
                "release-retirement-record"
              ]
            },
            "locator": {
              "type": "string",
              "minLength": 3,
              "maxLength": 512,
              "pattern": "^(?:template|release):[A-Za-z0-9@+_.:/#-]+$"
            }
          }
        },
        "successor_component_id": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/componentId"
            }
          ]
        },
        "pruned_at": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/timestamp"
            }
          ]
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "previous_paths",
        "retirement",
        "reintroduces_component_id"
      ],
      "properties": {
        "state": {
          "enum": [
            "active",
            "retired",
            "tombstoned"
          ]
        },
        "previous_paths": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        },
        "retirement": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/retirement"
            }
          ]
        },
        "reintroduces_component_id": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/componentId"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "active"
              }
            }
          },
          "then": {
            "properties": {
              "retirement": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "retired"
              }
            }
          },
          "then": {
            "properties": {
              "retirement": {
                "allOf": [
                  {
                    "$ref": "#/$defs/retirement"
                  },
                  {
                    "properties": {
                      "pruned_at": {
                        "type": "null"
                      }
                    }
                  }
                ]
              },
              "reintroduces_component_id": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "tombstoned"
              }
            }
          },
          "then": {
            "properties": {
              "retirement": {
                "allOf": [
                  {
                    "$ref": "#/$defs/retirement"
                  },
                  {
                    "properties": {
                      "pruned_at": {
                        "$ref": "#/$defs/timestamp"
                      }
                    }
                  }
                ]
              },
              "reintroduces_component_id": {
                "type": "null"
              }
            }
          }
        }
      ],
      "$comment": "Tombstoned IDs are terminal and permanently reserved. A non-null reintroduces_component_id is allowed only on a new active component ID and must resolve to a different tombstoned component. Readers reject self-reference, missing/non-tombstoned targets, cycles, reuse of the tombstoned ID, or mutation of the old tombstone; these cross-record constraints require semantic validation."
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transaction_id",
        "outcome"
      ],
      "properties": {
        "transaction_id": {
          "type": "string",
          "minLength": 7,
          "maxLength": 132,
          "pattern": "^txn:[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "outcome": {
          "enum": [
            "installed",
            "updated",
            "preserved-existing",
            "preserved-customization",
            "conflicted",
            "reported",
            "retired",
            "tombstoned"
          ]
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity",
        "provenance",
        "hashes",
        "lifecycle",
        "last_operation",
        "installed_at",
        "updated_at"
      ],
      "properties": {
        "identity": {
          "$ref": "#/$defs/identity"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "hashes": {
          "$ref": "#/$defs/hashes"
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "last_operation": {
          "$ref": "#/$defs/operation"
        },
        "installed_at": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/timestamp"
            }
          ]
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "identity": {
                "properties": {
                  "role": {
                    "const": "generated"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "provenance": {
                "properties": {
                  "ownership": {
                    "const": "derived-runtime"
                  },
                  "generated_from": {
                    "minItems": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "identity": {
                "properties": {
                  "role": {
                    "const": "canonical"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "provenance": {
                "properties": {
                  "ownership": {
                    "const": "template-managed"
                  },
                  "generated_from": {
                    "maxItems": 0
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "identity": {
                "properties": {
                  "role": {
                    "const": "project-owned"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "provenance": {
                "properties": {
                  "ownership": {
                    "const": "project-owned"
                  },
                  "generated_from": {
                    "maxItems": 0
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "identity": {
                "properties": {
                  "role": {
                    "const": "compatibility"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "provenance": {
                "properties": {
                  "ownership": {
                    "const": "legacy-compat"
                  },
                  "generated_from": {
                    "maxItems": 0
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lifecycle": {
                "properties": {
                  "state": {
                    "const": "retired"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "hashes": {
                "properties": {
                  "proposed_source": {
                    "type": "null"
                  }
                }
              },
              "last_operation": {
                "properties": {
                  "outcome": {
                    "const": "retired"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lifecycle": {
                "properties": {
                  "state": {
                    "const": "tombstoned"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "hashes": {
                "properties": {
                  "proposed_source": {
                    "type": "null"
                  },
                  "result_after": {
                    "type": "null"
                  }
                }
              },
              "last_operation": {
                "properties": {
                  "outcome": {
                    "const": "tombstoned"
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}

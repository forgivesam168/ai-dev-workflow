{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-dev-workflow:manifest-reconciliation-report:v1",
  "title": "AI Workflow Manifest Reconciliation Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["report_contract_version", "operation", "manifest_parse_state", "plan_identity", "report_identity", "source", "normalized_input_snapshot_identity", "mapped_component_decisions", "unmapped_records", "blocking_findings", "required_future_authorization", "no_write_confirmation", "volatile_display_envelope"],
  "properties": {
    "report_contract_version": {"const": 1},
    "operation": {"type": "string", "enum": ["conversion-plan", "reconcile"]},
    "manifest_parse_state": {"$ref": "#/$defs/manifestParseState"},
    "plan_identity": {"$ref": "#/$defs/planIdentity"},
    "report_identity": {"$ref": "#/$defs/reportIdentity"},
    "source": {"$ref": "#/$defs/sourceEvidence"},
    "normalized_input_snapshot_identity": {"$ref": "#/$defs/normalizedSnapshot"},
    "mapped_component_decisions": {"type": "array", "items": {"$ref": "#/$defs/mappedDecision"}},
    "unmapped_records": {"type": "array", "items": {"$ref": "#/$defs/unmappedRecord"}},
    "blocking_findings": {"type": "array", "items": {"$ref": "#/$defs/blockingFinding"}},
    "required_future_authorization": {"$ref": "#/$defs/authorization"},
    "no_write_confirmation": {"$ref": "#/$defs/noWrite"},
    "volatile_display_envelope": {"$ref": "#/$defs/volatileEnvelope"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nullableDigest": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
    "relativePath": {"type": "string", "pattern": "^[A-Za-z0-9@+_.-]+(?:/[A-Za-z0-9@+_.-]+)*$"},
    "manifestParseState": {"type": "object", "additionalProperties": false, "required": ["state", "schema_version", "diagnostic_category"], "properties": {"state": {"type": "string", "enum": ["missing", "valid-v1", "valid-v2", "valid-v3", "corrupt", "unsupported", "v3-validation-blocked", "source-blocked"]}, "schema_version": {"type": ["integer", "null"]}, "diagnostic_category": {"type": ["string", "null"]}}},
    "planIdentity": {"type": "object", "additionalProperties": false, "required": ["report_contract_version", "tool_version", "operation", "input_manifest_digest", "source_release_id", "selected_component_ids", "normalized_input_snapshot_identity"], "properties": {"report_contract_version": {"const": 1}, "tool_version": {"type": "string"}, "operation": {"type": "string", "enum": ["conversion-plan", "reconcile"]}, "input_manifest_digest": {"$ref": "#/$defs/nullableDigest"}, "source_release_id": {"type": ["string", "null"]}, "selected_component_ids": {"type": "array", "items": {"type": "string"}}, "normalized_input_snapshot_identity": {"$ref": "#/$defs/digest"}}},
    "reportIdentity": {"type": "object", "additionalProperties": false, "required": ["report_id", "canonical_body_digest"], "properties": {"report_id": {"type": "string", "pattern": "^report:[0-9a-f]{12}$"}, "canonical_body_digest": {"$ref": "#/$defs/digest"}}},
    "sourceEvidence": {"type": "object", "additionalProperties": false, "required": ["source_release_id", "schema_path", "schema_digest", "catalog_path", "catalog_digest"], "properties": {"source_release_id": {"type": ["string", "null"]}, "schema_path": {"$ref": "#/$defs/relativePath"}, "schema_digest": {"$ref": "#/$defs/nullableDigest"}, "catalog_path": {"$ref": "#/$defs/relativePath"}, "catalog_digest": {"$ref": "#/$defs/nullableDigest"}}},
    "normalizedSnapshot": {"type": "object", "additionalProperties": false, "required": ["digest", "inventory"], "properties": {"digest": {"$ref": "#/$defs/digest"}, "inventory": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}}}},
    "componentIdentity": {"type": "object", "additionalProperties": false, "required": ["id", "path", "path_key", "kind", "role"], "properties": {"id": {"type": "string", "pattern": "^cmp:[a-z0-9][a-z0-9._-]{2,127}$"}, "path": {"$ref": "#/$defs/relativePath"}, "path_key": {"$ref": "#/$defs/relativePath"}, "kind": {"type": "string"}, "role": {"type": "string"}}},
    "sourceIdentity": {"type": "object", "additionalProperties": false, "required": ["path", "release"], "properties": {"path": {"$ref": "#/$defs/relativePath"}, "release": {"type": "string"}}},
    "eligibility": {"type": "object", "additionalProperties": false, "required": ["eligible", "computation_version", "not_authority", "reason"], "properties": {"eligible": {"type": "boolean"}, "computation_version": {"type": "string"}, "not_authority": {"const": true}, "reason": {"type": "string"}}},
    "mappedDecision": {"type": "object", "additionalProperties": false, "required": ["component_identity", "ownership", "observed_hash", "baseline", "proposed_source_hash", "source", "generated_from", "classification", "classification_basis", "lifecycle_state", "stale_or_retirement_reason", "previous_path_hashes", "proposed_action", "eligibility"], "properties": {"component_identity": {"$ref": "#/$defs/componentIdentity"}, "ownership": {"type": "string"}, "observed_hash": {"$ref": "#/$defs/nullableDigest"}, "baseline": {"$ref": "#/$defs/nullableDigest"}, "proposed_source_hash": {"$ref": "#/$defs/nullableDigest"}, "source": {"$ref": "#/$defs/sourceIdentity"}, "generated_from": {"type": "array", "items": {"type": "string"}}, "classification": {"type": "string", "enum": ["untouched", "customized", "project-owned", "legacy", "unknown", "derived-customized", "conflicted", "not-applicable"]}, "classification_basis": {"type": "string"}, "lifecycle_state": {"type": "string"}, "stale_or_retirement_reason": {"type": "string"}, "previous_path_hashes": {"type": "object", "additionalProperties": {"$ref": "#/$defs/nullableDigest"}}, "proposed_action": {"type": "string", "enum": ["preserve", "report", "block"]}, "eligibility": {"$ref": "#/$defs/eligibility"}}},
    "unmappedRecord": {"type": "object", "additionalProperties": false, "required": ["record", "classification", "reason"], "properties": {"record": {"type": "string"}, "classification": {"type": "string", "enum": ["legacy", "unknown", "conflicted"]}, "reason": {"type": "string"}}},
    "blockingFinding": {"type": "object", "additionalProperties": false, "required": ["code", "detail"], "properties": {"code": {"type": "string"}, "detail": {"type": "string"}}},
    "authorization": {"type": "object", "additionalProperties": false, "required": ["not_authority", "approval_supplied", "future_current_task_action_specific_approval_required", "execution_time_revalidation_required", "delete_action"], "properties": {"not_authority": {"const": true}, "approval_supplied": {"const": false}, "future_current_task_action_specific_approval_required": {"const": true}, "execution_time_revalidation_required": {"const": true}, "delete_action": {"const": false}}},
    "snapshotRecord": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "size", "mtime_ns"], "properties": {"path": {"$ref": "#/$defs/relativePath"}, "digest": {"$ref": "#/$defs/digest"}, "size": {"type": "integer", "minimum": 0}, "mtime_ns": {"type": "integer", "minimum": 0}}},
    "noWrite": {"type": "object", "additionalProperties": false, "required": ["writes_performed", "pre_manifest_digest", "post_manifest_digest", "pre_catalog_digest", "post_catalog_digest", "pre_source_snapshot_digest", "post_source_snapshot_digest", "pre_target_snapshot_digest", "post_target_snapshot_digest", "inventory_unchanged", "timestamps_unchanged", "link_metadata_unchanged", "git_presence_unchanged", "forbidden_artifacts_before", "forbidden_artifacts_after", "forbidden_artifacts_unchanged", "pre_inventory", "post_inventory", "selected_target_hashes"], "properties": {"writes_performed": {"type": "boolean"}, "pre_manifest_digest": {"$ref": "#/$defs/nullableDigest"}, "post_manifest_digest": {"$ref": "#/$defs/nullableDigest"}, "pre_catalog_digest": {"$ref": "#/$defs/nullableDigest"}, "post_catalog_digest": {"$ref": "#/$defs/nullableDigest"}, "pre_source_snapshot_digest": {"$ref": "#/$defs/digest"}, "post_source_snapshot_digest": {"$ref": "#/$defs/digest"}, "pre_target_snapshot_digest": {"$ref": "#/$defs/digest"}, "post_target_snapshot_digest": {"$ref": "#/$defs/digest"}, "inventory_unchanged": {"type": "boolean"}, "timestamps_unchanged": {"type": "boolean"}, "link_metadata_unchanged": {"type": "boolean"}, "git_presence_unchanged": {"type": "boolean"}, "forbidden_artifacts_before": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}}, "forbidden_artifacts_after": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}}, "forbidden_artifacts_unchanged": {"type": "boolean"}, "pre_inventory": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}}, "post_inventory": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}}, "selected_target_hashes": {"type": "object", "additionalProperties": {"$ref": "#/$defs/nullableDigest"}}}},
    "volatileEnvelope": {"type": "object", "additionalProperties": false, "required": ["timestamp", "host"], "properties": {"timestamp": {"type": "string"}, "host": {"type": ["string", "null"]}}}
  }
}
